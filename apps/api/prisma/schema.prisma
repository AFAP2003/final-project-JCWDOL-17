generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

// This is used for signup with email 
model SignupToken {
  id           String   @id @default(uuid())
  email        String   @unique
  token        String   @unique
  firstName    String
  lastName     String
  referralCode String?
  expiredAt    DateTime
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  avatarUrl String?
  firstName String?
  lastName  String?

  // User's personal referral code that others can use when signing up
  referralCode String? @unique

  // Referral relationships
  referrals    User[]  @relation("SignupReferral") // A list of users who signed up using this user's referral code.
  referredBy   User?   @relation("SignupReferral", fields: [referredById], references: [id]) // The user who invited this user to sign up 
  referredById String? // The ID of the user who invited this user.
}

// /* ---------------------- ENUM RELATED THING ---------------------- */

enum Role {
  USER
  ADMIN
  SUPER
}
