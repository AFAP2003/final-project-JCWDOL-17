<html>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>
      Email Verification
    </title>
    <style>
      body {
      font-family: Arial, sans-serif;
      background-color: #f4f4f4;
      margin: 0;
      padding: 0;
    }
    .container {
      max-width: 600px;
      margin: 40px auto;
      background: #ffffff;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      text-align: center;
    }
    h1 {
      color: #333;
    }
    p {
      color: #555;
      font-size: 16px;
    }
    .btn {
      display: inline-block;
      background-color: #007bff;
      color: #ffffff;
      text-decoration: none;
      padding: 12px 20px;
      border-radius: 5px;
      font-size: 16px;
      margin-top: 20px;
    }
    .btn:hover {
      background-color: #0056b3;
    }
    .footer {
      margin-top: 20px;
      font-size: 14px;
      color: #777;
    }
    </style>
  </head>

  <body>
    <div class='container'>
      <h1>
        Signup Confirmation
      </h1>
      <p>
        Hello {{receiver}},
      </p>
      <p>
        Thank you for signing up. Please verify your email address by clicking
        the button below:
      </p>
      <a href='{{confirmationLink}}' class='btn'>
        Verify Email
      </a>
      <p>
        If you did not create an account, please ignore this email.
      </p>
      <p class='footer'>
        &copy; {{year}} Your Company. All rights reserved.
      </p>
    </div>
  </body>
</html>